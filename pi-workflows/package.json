{
  "name": "pi-workflows",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deterministic multi-agent workflows for Pi with durable artifacts and declarative UI.",
  "main": "index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm test"
  },
  "dependencies": {
    "acorn": "latest",
    "ajv": "latest"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@types/node": "latest",
    "typebox": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "pi": {
    "extensions": [
      "index.ts"
    ],
    "workflows": [
      "workflows/*.js"
    ]
  }
}
