{
  "name": "code-feedback",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Touched-line LSP diagnostics and formatter feedback for Pi.",
  "main": "index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run typecheck && npm test",
    "perf": "node --expose-gc scripts/perf-bench.mjs",
    "perf:live": "node --expose-gc scripts/perf-bench.mjs --live",
    "smoke:lsp": "node scripts/real-lsp-smoke.mjs",
    "release:check": "npm run check && node --expose-gc scripts/release-gate.mjs",
    "release:check:live": "npm run release:check && npm run smoke:lsp"
  },
  "devDependencies": {
    "@types/node": "^22.15.21"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.80.10",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.3.0"
  }
}
