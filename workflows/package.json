{
  "name": "workflows",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Durable named TypeScript workflows for one systemd/Btrfs Linux host.",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:flows": "tsc -p tsconfig.flows.json",
    "typecheck:conformance": "tsc -p tests/conformance/typecheck/tsconfig.json",
    "test:conformance": "node --test tests/conformance/reference/**/*.case.mjs",
    "test:commands": "vitest run tests/command-executor.test.ts",
    "test:systemd": "vitest run tests/systemd-substrate.test.ts tests/command-executor.test.ts",
    "test:coordinator": "vitest run tests/workflow-coordinator.test.ts",
    "test:semantic-engine": "vitest run tests/workflow-semantic-engine.test.ts",
    "test:unit": "vitest run --no-file-parallelism",
    "test": "npm run test:unit && npm run test:conformance",
    "check": "npm run typecheck && npm run typecheck:flows && npm run typecheck:conformance && npm test"
  },
  "dependencies": {
    "acorn": "8.16.0",
    "ajv": "8.20.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.10",
    "typebox": "1.1.39"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@types/node": "25.9.1",
    "typebox": "1.1.39",
    "vitest": "4.1.7"
  },
  "pi": {
    "extensions": [
      "index.ts"
    ]
  }
}
