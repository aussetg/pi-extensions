{
  "name": "pi-code-feedback",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pi extension for touched-line LSP diagnostics and formatter feedback.",
  "main": "index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run typecheck && npm test",
    "perf": "node --expose-gc scripts/perf-bench.mjs",
    "perf:live": "node --expose-gc scripts/perf-bench.mjs --live"
  },
  "devDependencies": {
    "@types/node": "^22.15.21"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.80.6",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.3.0"
  }
}
